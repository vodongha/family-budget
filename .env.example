# ─── Oracle Autonomous Database (thin mode, wallet) ───────────────────────────
# DSN = a TNS alias from the wallet's tnsnames.ora (e.g. <dbname>_high / _tp).
ORACLE_USER=ADMIN
ORACLE_PASSWORD=change-me
ORACLE_DSN=familybudget_tp
# Optional: a dedicated schema for this app's tables, so several apps can share
# one ADB without colliding. When set, every connection runs
# ALTER SESSION SET CURRENT_SCHEMA, so Alembic/the ORM use this schema instead of
# the connecting user's default. The schema (an Oracle user with quota) must
# already exist. Leave empty to use the connecting user's own schema.
ORACLE_SCHEMA=
# Directory holding the unzipped wallet (cwallet.sso, tnsnames.ora, ...).
# Inside Docker this is the mounted path; locally point it at ./wallet.
WALLET_DIR=/app/wallet
# Wallet password set when downloading the wallet from the OCI console.
WALLET_PASSWORD=change-me

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
# Long-lived by design: the session lasts until the user explicitly logs out
# (or the app drops the token on a 401). ~10 years. See app/core/config.py.
ACCESS_TOKEN_EXPIRE_MINUTES=5256000

# ─── Redis (Celery broker + cache) ────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── App ──────────────────────────────────────────────────────────────────────
ENV=development
